# ============================================================
# 환경 변수 템플릿 — .env.dev / .env.prod 를 별도로 만들어 사용
# 이 파일은 git에 커밋합니다. 실제 값이 담긴 .env.* 파일은 .gitignore에 추가하세요.
# ============================================================

# ── 환경 구분 ─────────────────────────────────────────────
NODE_ENV=development           # development | production

# ── Firebase 프로젝트 ─────────────────────────────────────
# prod: pour-app-prod
# dev:  pour-app-dev (예정)
FIREBASE_PROJECT_ID=pour-app-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@pour-app-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Google Cloud Storage 백업 버킷 ──────────────────────────
# 형식: gs://버킷명
GCS_BUCKET=gs://pour-app-prod-backup

# ── GitHub 백업 레포 (JSON 커밋용) ─────────────────────────
# Firestore 데이터를 JSON으로 이 레포에 자동 커밋
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=netformrnd-lab/pour-construction-form
GITHUB_BACKUP_BRANCH=backup/firestore-snapshots

# ── 백업 설정 ────────────────────────────────────────────
# 백업할 컬렉션 목록 (콤마 구분)
BACKUP_COLLECTIONS=leads,leads-store,leads-grohome,leads-method,activities,site-resources,partner-companies

# 보관 기간 (일) — 이보다 오래된 GCS 백업 자동 삭제
BACKUP_RETENTION_DAYS=30

# ── Cloudflare Worker (Claude API 프록시) ────────────────
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
WORKER_SECRET=your-worker-secret-here
