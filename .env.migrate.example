# ============================================================
# 마이그레이션 환경 변수 — .env.migrate 파일로 복사하여 사용
# .env.migrate 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── 원본 프로젝트 (pour-app-prod) ──────────────────────────
SOURCE_PROJECT_ID=pour-app-prod
SOURCE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@pour-app-prod.iam.gserviceaccount.com
SOURCE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── 대상 프로젝트 (새 프로젝트) ────────────────────────────
TARGET_PROJECT_ID=your-new-project-id
TARGET_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-new-project.iam.gserviceaccount.com
TARGET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
