// ============================================================
// 통합 Firestore 보안 규칙
// 적용 프로젝트: pour-app-new (단일 프로젝트로 통합)
//   - 박람회·영업앱: admin.html, index.html, defect-diagnosis.html 등
//   - POUR스토어 신규: pourstore-renewal/admin·portal·kiosk·preview
// ============================================================
// 배포 방법: FIREBASE-DEPLOY.md 참조
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // 박람회 + 영업앱 컬렉션 (pour-app-new)
    // ─────────────────────────────────────────────
    // 리드 + 백업
    match /leads/{doc}              { allow read, write: if true; }
    match /leads-store/{doc}        { allow read, write: if true; }
    match /leads-grohome/{doc}      { allow read, write: if true; }
    match /leads-method/{doc}       { allow read, write: if true; }
    match /leads-backups/{doc}      { allow read, write: if true; }
    match /history/{doc}            { allow read, write: if true; }

    // 설정
    match /config/{doc}             { allow read, write: if true; }
    match /app-config/{doc}         { allow read, write: if true; }

    // QR + 짧은 링크
    match /qr-stats/{doc}           { allow read, write: if true; }
    match /short-links/{doc}        { allow read, write: if true; }

    // 영업 활동·아웃바운드
    match /activities/{doc}         { allow read, write: if true; }
    match /outbound-solution/{doc}  { allow read, write: if true; }
    match /outbound-method/{doc}    { allow read, write: if true; }
    match /outbound-store/{doc}     { allow read, write: if true; }
    match /outbound-grohome/{doc}   { allow read, write: if true; }

    // 문의·사이트 데이터
    match /partner-inquiries/{doc}  { allow read, write: if true; }
    match /dealer-inquiries/{doc}   { allow read, write: if true; }
    match /site-inquiries/{doc}     { allow read, write: if true; }
    match /site-metrics/{doc}       { allow read, write: if true; }
    match /site-resources/{doc}     { allow read, write: if true; }

    // 하자진단·완공현장
    match /defect-sites/{doc}       { allow read, write: if true; }
    match /defect-diagnosis/{doc}   { allow read, write: if true; }
    match /defect-photos/{doc}      { allow read, write: if true; }
    match /defect-templates/{doc}   { allow read, write: if true; }
    match /step-photos/{doc}        { allow read, write: if true; }
    match /process-guide/{doc}      { allow read, write: if true; }

    // 영업자료·제안서·콘텐츠
    match /sales-docs/{doc}         { allow read, write: if true; }
    match /proposal-slides/{doc}    { allow read, write: if true; }
    match /method-content/{doc}     { allow read, write: if true; }
    match /method-links/{doc}       { allow read, write: if true; }
    match /products/{doc}           { allow read, write: if true; }

    // 고객 리포트·NPS·SMS 로그
    match /customer-reports/{doc}   { allow read, write: if true; }
    match /nps-surveys/{doc}        { allow read, write: if true; }
    match /sms-logs/{doc}           { allow read, write: if true; }

    // ─────────────────────────────────────────────
    // POUR스토어 신규 컬렉션 (pourstore-renewal/*)
    // ─────────────────────────────────────────────
    match /matching-requests/{doc}         { allow read, write: if true; }
    match /partner-companies/{doc}         { allow read, write: if true; }
    match /matching-rules/{doc}            { allow read, write: if true; }
    match /dealers/{doc}                   { allow read, write: if true; }
    match /dealer-orders/{doc}             { allow read, write: if true; }
    match /purchase-orders/{doc}           { allow read, write: if true; }
    match /pourstore-renewal-builder/{doc} { allow read, write: if true; }
    // history 서브컬렉션 — 1MB 한도 회피용 분리 저장 (state/history/{key})
    match /pourstore-renewal-builder/{doc}/{subcoll=**} { allow read, write: if true; }
    match /pourstore-renewal-instances/{doc} { allow read, write: if true; }
    match /pourstore-renewal-products/{doc}  { allow read, write: if true; }
    match /pourstore-renewal-listings/{doc}  { allow read, write: if true; }

    // ─────────────────────────────────────────────
    // POUR스토어 업무관리 (work-*) — pourstore-renewal/admin
    // ─────────────────────────────────────────────
    match /work-tasks/{doc}         { allow read, write: if true; }
    match /work-templates/{doc}     { allow read, write: if true; }
    match /work-sales/{doc}         { allow read, write: if true; }
    match /work-categories/{doc}    { allow read, write: if true; }
    match /work-links/{doc}         { allow read, write: if true; }
    match /work-manuals/{doc}       { allow read, write: if true; }

    // ─────────────────────────────────────────────
    // 어드민 담당자 마스터 — pourstore-renewal/admin
    // 향후 OTP 인증(admin-auth) 도입 시 read는 활성 담당자에 한해 허용,
    // write는 isAdmin=true 담당자에 한해 허용하도록 보강 예정 (CLAUDE.md PART 14).
    // ─────────────────────────────────────────────
    match /staff/{doc}              { allow read, write: if true; }

    // ─────────────────────────────────────────────
    // KPI 업무관리센터 (POUR OS → React 흡수) — pour-* 8종
    // 모든 문서는 staffId(어드민 staff 컬렉션의 doc.id)로 소유자 식별.
    // 향후 OTP 인증 도입 시 read 본인+팀 / write 본인만으로 제한 예정.
    // ─────────────────────────────────────────────
    match /pour-tasks/{doc}         { allow read, write: if true; }
    match /pour-recurring/{doc}     { allow read, write: if true; }
    match /pour-projects/{doc}      { allow read, write: if true; }
    match /pour-objectives/{doc}    { allow read, write: if true; }
    match /pour-keyresults/{doc}    { allow read, write: if true; }
    match /pour-kpis/{doc}          { allow read, write: if true; }
    match /pour-meetings/{doc}      { allow read, write: if true; }
    match /pour-journals/{doc}      { allow read, write: if true; }
    match /pour-ai-reviews/{doc}    { allow read, write: if true; }  // 🤖 AI 주간 점검 결과 누적 (데이터 자산화)

    // ─────────────────────────────────────────────
    // POUR스토어 업무관리 — workmgmt.html
    // 단일 문서(main)에 45개 프로젝트 완료 상태 통합 저장.
    // 모든 사용자가 같은 문서를 읽고 쓰므로 실시간 협업 가능.
    // 향후 OTP 인증 도입 시 활동 담당자만 쓰기 허용으로 강화 예정.
    // ─────────────────────────────────────────────
    match /work-mgmt/{doc}          { allow read, write: if true; }
    // 거래코드·채널 관리 (KR 하위 세부 채널 — G 조달청·관급 등 신설/편집)
    match /work-channels/{doc}      { allow read, write: if true; }

    // ─────────────────────────────────────────────
    // 기본 정책: 명시되지 않은 컬렉션은 차단
    // ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
    match /users/{doc}              { allow read, write: if true; }
    match /goals/{doc}              { allow read, write: if true; }
    match /mainKPIs/{doc}           { allow read, write: if true; }
    match /subKPIs/{doc}            { allow read, write: if true; }
    match /projects/{doc}           { allow read, write: if true; }
    match /tasks/{doc}              { allow read, write: if true; }
    match /events/{doc}             { allow read, write: if true; }
    match /events/{doc}/actions/{a} { allow read, write: if true; }
    match /personalGoals/{doc}      { allow read, write: if true; }
    match /retros/{doc}             { allow read, write: if true; }
    match /aiReviews/{doc}          { allow read, write: if true; }
    match /activityKPIs/{doc}       { allow read, write: if true; }

// ⚠️ MVP 단계 보안 정책 안내
// ────────────────────────────────────────────────
// 현재는 인증 없이 read/write 허용 (MVP 운영 단계).
// 운영 안정화 후 단계별 보안 강화 권장 — FIREBASE-DEPLOY.md 참조.
