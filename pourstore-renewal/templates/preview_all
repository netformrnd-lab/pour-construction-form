<script>
(function(){
  var sw = document.querySelectorAll('.swatch-btn');
  var cards = document.querySelectorAll('.psh-card');
  sw.forEach(function(b){
    b.addEventListener('click', function(){
      sw.forEach(function(x){ x.classList.remove('on'); });
      b.classList.add('on');
      var cat = b.dataset.cat;
      cards.forEach(function(c){
        if(cat === 'all' || c.dataset.cat === cat){ c.classList.remove('hide'); }
        else { c.classList.add('hide'); }
      });
    });
  });
  var slides = document.querySelectorAll('.slide');
  var dots = document.querySelectorAll('.carousel-dot');
  var counter = document.querySelector('.carousel-counter .cur');
  var cur = 0, timer;
  function go(i){
    slides[cur].classList.remove('active');
    dots[cur].classList.remove('active');
    cur = (i + slides.length) % slides.length;
    slides[cur].classList.add('active');
    dots[cur].classList.add('active');
    if(counter) counter.textContent = String(cur+1).padStart(2,'0');
    resetTimer();
  }
  function resetTimer(){ clearInterval(timer); timer = setInterval(function(){ go(cur+1); }, 5000); }
  dots.forEach(function(d,i){ d.addEventListener('click', function(){ go(i); }); });
  document.getElementById('cs-prev').addEventListener('click', function(){ go(cur-1); });
  document.getElementById('cs-next').addEventListener('click', function(){ go(cur+1); });
  var car = document.getElementById('carousel');
  car.addEventListener('mouseenter', function(){ clearInterval(timer); });
  car.addEventListener('mouseleave', resetTimer);
  resetTimer();
})();
</script>
